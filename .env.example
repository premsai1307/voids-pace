# Copy this file to .env (or export these as real environment variables)
# and fill in your own Claude API key to enable live AI-assisted asset
# tagging. Without it, the app runs perfectly well using a deterministic
# offline fallback (see backend/ai_assistant.py).

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Optional
PORT=5001
FLASK_DEBUG=true
